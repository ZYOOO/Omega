{
  "name": "omega-ai-delivery-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "web:dev": "vite --config apps/web/vite.config.ts",
    "desktop:dev": "electron apps/desktop/src/main.cjs",
    "desktop:pilot": "electron apps/desktop/src/pilot-main.cjs",
    "build": "tsc -b && vite build --config apps/web/vite.config.ts",
    "web:build": "vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "local:runner:demo": "node scripts/local-runner-demo.mjs",
    "local-runtime:dev": "go run ./services/local-runtime/cmd/omega-local-runtime",
    "omega": "go run ./services/local-runtime/cmd/omega",
    "mission-control:api": "go run ./services/local-runtime/cmd/omega-local-runtime",
    "mission-control:api:node": "node scripts/local-runner-api.mjs",
    "go:test": "go test ./...",
    "codex:proof:smoke": "node scripts/codex-proof-smoke.mjs",
    "test": "vitest run --config apps/web/vite.config.ts",
    "test:watch": "vitest --config apps/web/vite.config.ts",
    "coverage": "vitest run --coverage --config apps/web/vite.config.ts",
    "lint": "tsc -b --pretty false"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^41.3.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
